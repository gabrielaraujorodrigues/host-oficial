# Token interno do webhook (use um token longo e único)
INTERNAL_WEBHOOK_TOKEN=coloque-um-token-longo-e-unico

# IPs permitidos para o webhook interno
INTERNAL_WEBHOOK_ALLOWED_IPS=127.0.0.1,::1

# URL base do painel de controle
PANEL_BASE_URL=https://seu-painel.com

# URL de callback do painel
PANEL_CALLBACK_URL=

# Token de callback do painel (token da API do bot no painel)
PANEL_CALLBACK_TOKEN=coloque-o-token-da-api-do-bot-no-painel

# Token do dashboard (proteja o JSON se for expor)
DASHBOARD_TOKEN=proteja-o-json-se-for-expor

# Habilitar dashboard
DASHBOARD_ENABLED=true

# Porta do dashboard
DASHBOARD_PORT=3001

# Registrar execuções de comandos nos logs
LOG_COMMAND_EXECUTIONS=true

# Habilitar logs estruturados
STRUCTURED_LOG_ENABLED=true

# Telemetria ao vivo no console
CONSOLE_LIVE_TELEMETRY=false

# Modo de vinculação: code (código) ou qr (QR code)
PAIRING_MODE=code

# Número para vinculação (com código do país, ex: 5511999999999)
PAIRING_NUMBER=5511999999999
